{
  "transform": {
    "^.+\\.(t|j)sx?$": "@swc/jest"
  },
  "testMatch": ["<rootDir>/packages/*/tests/Scenarios.test.ts"],
  "collectCoverage": true,
  "coverageDirectory": "<rootDir>/coverage",
  "collectCoverageFrom": ["<rootDir>/packages/*/src/**/*.ts"],
  "coverageReporters": ["clover", "json", "lcov", "text", "html"],
  "coverageThreshold": {
    "global": {
      "statements": 100,
      "functions": 100,
      "lines": 100
    }
  }
}
